<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="72dp"
    android:background="?selectableItemBackground"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingLeft="16dp"
    android:paddingEnd="16dp"
    android:paddingRight="16dp"
    android:paddingBottom="16dp">

    <ImageView
        android:id="@+id/creatorsItemAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/creators_avatar_description"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/creatorsItemName"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="bottom"
        android:textSize="16sp"
        tools:text="@tools:sample/lorem"
        android:layout_alignParentTop="true"
        android:layout_toEndOf="@id/creatorsItemAvatar"
        android:layout_toRightOf="@id/creatorsItemAvatar"
        android:layout_marginLeft="16dp"
        android:layout_marginStart="16dp" />

    <TextView
        android:id="@+id/creatorsItemSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="?android:textColorSecondary"
        android:textSize="14sp"
        tools:text="@tools:sample/lorem"
        android:layout_below="@id/creatorsItemName"
        android:layout_toEndOf="@id/creatorsItemAvatar"
        android:layout_toRightOf="@id/creatorsItemAvatar"
        android:layout_marginLeft="16dp"
        android:layout_marginStart="16dp" />
</RelativeLayout>
