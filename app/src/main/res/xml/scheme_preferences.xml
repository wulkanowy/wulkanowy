<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory android:title="@string/pref_view_header">
        <ListPreference
            android:defaultValue="0"
            android:entries="@array/startup_tab_entries"
            android:entryValues="@array/startup_tab_value"
            android:key="startup_menu"
            android:summary="%s"
            android:title="@string/pref_view_list" />
        <SwitchPreference
            android:defaultValue="true"
            android:key="attendance_present"
            android:title="@string/pref_view_present" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/pref_about_description">
        <Preference
            android:key="version"
            android:title="@string/pref_about_version" />
        <Preference
            android:key="libraries"
            android:summary="@string/pref_about_libraries_summary"
            android:title="@string/pref_about_libraries" />
        <Preference android:title="@string/pref_about_support">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/wulkanowy/wulkanowy" />
        </Preference>
    </PreferenceCategory>
</PreferenceScreen>
